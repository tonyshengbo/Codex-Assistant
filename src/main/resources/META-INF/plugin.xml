<idea-plugin>
    <id>com.auracode.assistant</id>
    <name>Aura Code</name>
    <vendor email ="tonyshengbo@foxmail.com">Aura Code</vendor>

    <resource-bundle>messages.AuraCodeBundle</resource-bundle>
    <description><![CDATA[
        <p><b>Aura Code</b> brings the Aura Code runtime directly into IntelliJ IDEA, so you can plan, discuss, and execute coding tasks without leaving the IDE.</p>
        <p><b>Core capabilities</b></p>
        <ul>
            <li>Native chat tool window for in-IDE collaboration</li>
            <li>Project-scoped multi-tab sessions with resumable history</li>
            <li>Rich context input with file mentions and attachments</li>
            <li>Built-in plan/approval workflows with diff review</li>
            <li>MCP-aware environment and server management</li>
        </ul>
        <p><b>Outcome:</b> Ship changes faster while keeping control inside existing development workflows.</p>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.java</depends>
    <depends>Git4Idea</depends>

    <applicationListeners>
        <listener
                class="com.auracode.assistant.toolwindow.bootstrap.InitializeSkikoLibraryPathEarly"
                topic="com.intellij.ide.AppLifecycleListener"/>
    </applicationListeners>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow
                id="Aura Code"
                factoryClass="com.auracode.assistant.toolwindow.bootstrap.AgentToolWindowFactory"
                anchor="right"
                icon="/icons/toolwindow-stripe.svg"
                canCloseContents="false"/>
        <notificationGroup
                id="Aura Code Chat Completion"
                displayType="BALLOON"
                key="notification.chatCompletion.title"/>

    </extensions>

    <actions>
        <action id="com.auracode.assistant.QuickOpen"
                class="com.auracode.assistant.actions.QuickOpenAction"
                text="%action.open.text"
                description="%action.open.description">
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl K"/>
            <keyboard-shortcut keymap="Mac OS X" first-keystroke="meta K"/>
        </action>
        <action id="com.auracode.assistant.AskAuraBuildProblem"
                class="com.auracode.assistant.actions.AskAuraBuildProblemAction"
                text="%action.ask.aura.build.problem.text"
                description="%action.ask.aura.build.problem.description">
            <add-to-group group-id="ProblemsView.ToolWindow.TreePopup" anchor="before" relative-to-action="ProblemsView.CopyProblemDescription"/>
        </action>
        <action id="com.auracode.assistant.AskAuraSelectedCode"
                class="com.auracode.assistant.actions.AskAuraSelectedCodeAction"
                text="%action.ask.aura.selected.code.text"
                description="%action.ask.aura.selected.code.description">
            <add-to-group group-id="EditorPopupMenu" anchor="first"/>
        </action>
        <action id="com.auracode.assistant.AskAuraCurrentFile"
                class="com.auracode.assistant.actions.AskAuraCurrentFileAction"
                text="%action.ask.aura.current.file.text"
                description="%action.ask.aura.current.file.description">
            <add-to-group group-id="ProjectViewPopupMenu" anchor="first"/>
            <add-to-group group-id="EditorTabPopupMenu" anchor="first"/>
        </action>
        <action id="com.auracode.assistant.GenerateCommitMessage"
                class="com.auracode.assistant.commit.CommitMessageGenerateAction"
                text="%action.generate.commit.message.text"
                description="%action.generate.commit.message.description"
                icon="/icons/toolwindow-stripe.svg">
            <add-to-group group-id="Vcs.MessageActionGroup" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
